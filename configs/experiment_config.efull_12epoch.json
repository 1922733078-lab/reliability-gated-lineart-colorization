{
  "dataset_root": "data/train",
  "color_dir_name": "color",
  "lineart_dir_name": "lineart",
  "validation_dataset_root": "data/validation",
  "validation_color_dir_name": "color",
  "validation_lineart_dir_name": "lineart",
  "prefer_external_validation_dataset": true,
  "helper_tools_root": "tools/helper_metrics",
  "output_root": "outputs/efull_adamw8bit_12epoch",
  "inference_archive_root": "artifacts/inference_archive",
  "use_all_training_pairs_for_training": true,
  "train_ratio": 0.8,
  "val_ratio": 0.1,
  "test_ratio": 0.1,
  "split_seed": 42,
  "image_width": 768,
  "image_height": 1024,
  "batch_size": 1,
  "epochs": 12,
  "gradient_accumulation_steps": 4,
  "learning_rate": 0.000001,
  "weight_decay": 0.0001,
  "optimizer_name": "adamw8bit",
  "lr_scheduler_name": "constant_with_warmup",
  "warmup_steps": 0,
  "enable_wgan_gp": false,
  "wgan_critic_steps": 1,
  "wgan_start_epoch": 4,
  "wgan_warmup_epochs": 4,
  "critic_image_size": 128,
  "wgan_generator_weight": 0.015,
  "wgan_reconstruction_weight": 0.2,
  "anti_flat_color_weight": 0.18,
  "anti_flat_color_min_std": 0.18,
  "latent_reconstruction_weight": 0.01,
  "latent_distribution_weight": 0.005,
  "latent_local_variance_weight": 0.0,
  "latent_gradient_weight": 0.005,
  "latent_global_flatness_weight": 0.01,
  "latent_global_flatness_target_std_ratio": 1.0,
  "latent_global_flatness_target_range_ratio": 1.0,
  "latent_local_variance_kernel_size": 3,
  "latent_local_variance_target_ratio": 0.95,
  "checkpoint_interval_steps": 200,
  "save_every_epoch": true,
  "eval_every_epoch": true,
  "defer_generation_metrics_until_seed_end": true,
  "max_eval_samples": 20,
  "mixed_precision": "fp16",
  "num_workers": 2,
  "seed": 42,
  "seed_list": [42, 123, 456],
  "prompt_template": "masterpiece, best quality, lineart colorization, harmonious colors, rich details, traditional art palette, clean cel shading",
  "negative_prompt": "monochrome, grayscale, lowres, blurry, deformed, oversaturated, muddy colors, text, watermark, signature",
  "base_model": "",
  "controlnet_model": "",
  "controlnet_conditioning_scale": 1.0,
  "canny_low_threshold": 100,
  "canny_high_threshold": 200,
  "fixed_threshold_value": 0.08,
  "adapter_channels": 32,
  "adapter_blocks": 2,
  "enable_adapter_variational_bottleneck": true,
  "adapter_variational_latent_channels": 12,
  "adapter_variational_bottleneck_channels": 24,
  "adapter_variational_decoder_channels": 16,
  "adapter_variational_dropout": 0.05,
  "adapter_variational_logvar_min": -6.0,
  "adapter_variational_logvar_max": 2.0,
  "adapter_variational_reconstruction_weight": 0.08,
  "adapter_variational_beta_start": 0.0005,
  "adapter_variational_beta_end": 0.02,
  "adapter_variational_anneal_epochs": 4,
  "adapter_variational_free_bits": 0.02,
  "latent_snapshot_samples": 3,
  "lora_rank": 16,
  "lora_alpha": 32,
  "lora_dropout": 0.05,
  "lora_target_profile": "attention_only",
  "enable_epoch_sanity_check": true,
  "epoch_sanity_check_samples": 1,
  "epoch_sanity_check_inference_steps": 10,
  "epoch_sanity_check_guidance_scale": 5.5,
  "epoch_sanity_min_std": 18.0,
  "epoch_sanity_min_dynamic_range": 72.0,
  "epoch_sanity_min_gradient_mean": 1.25,
  "epoch_sanity_target_std_ratio": 0.30,
  "epoch_sanity_target_dynamic_range_ratio": 0.378,
  "epoch_sanity_target_gradient_ratio": 0.31,
  "epoch_sanity_warning_enabled": true,
  "epoch_sanity_warning_min_ratio": 1.02,
  "epoch_sanity_warning_drop_ratio": 0.12,
  "epoch_sanity_recovery_lr_scale": 0.4,
  "epoch_sanity_recovery_severe_lr_scale": 0.3,
  "epoch_sanity_recovery_min_lr": 0.000001,
  "epoch_sanity_recovery_epochs": 2,
  "epoch_sanity_recovery_latent_reconstruction_weight": 0.02,
  "epoch_sanity_recovery_latent_distribution_weight": 0.015,
  "epoch_sanity_recovery_latent_local_variance_weight": 0.02,
  "epoch_sanity_recovery_latent_gradient_weight": 0.02,
  "epoch_sanity_recovery_latent_global_flatness_weight": 0.06,
  "epoch_sanity_recovery_image_reconstruction_weight": 0.002,
  "epoch_sanity_recovery_image_flat_color_weight": 0.008,
  "epoch_sanity_recovery_image_gradient_weight": 0.004,
  "epoch_sanity_recovery_weight_multiplier_step": 0.1,
  "epoch_sanity_recovery_max_weight_multiplier": 1.2,
  "stop_training_on_epoch_sanity_failure": true,
  "enable_gradient_checkpointing": true,
  "enable_xformers": true,
  "cpu_offload": false,
  "device": "cuda",
  "record_environment_lock": true
